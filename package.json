{
  "name": "vinext-app-router-cloudflare",
  "type": "module",
  "private": true,
  "scripts": {
    "content:generate": "node scripts/generate-mdx-content.mjs",
    "dev": "npm run content:generate && vp dev",
    "build": "npm run content:generate && vp build",
    "preview": "npm run content:generate && vp preview",
    "typecheck": "npm run content:generate && vp exec tsc --noEmit",
    "test": "npm run content:generate && vp test",
    "check": "npm run typecheck && npm run test",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.25.0",
    "@mdx-js/mdx": "^3.1.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitejs/plugin-rsc": "^0.5.19",
    "gray-matter": "^4.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-server-dom-webpack": "^19.2.4",
    "vinext": "0.0.31",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.12",
    "wrangler": "^4.66.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "typescript": "^5.9.2",
    "vite-plus": "0.1.12"
  },
  "packageManager": "pnpm@10.32.1"
}
